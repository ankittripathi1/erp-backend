generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AcademicTerm {
  id BigInt @id @default(autoincrement())
  academic_year_id BigInt
  academic_year AcademicYear @relation("AcademicTerm_academic_year_AcademicYear", fields: [academic_year_id], references: [id])
  name String
  term_type String
  start_date DateTime?
  end_date DateTime?
  is_current Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  is_active Boolean @default(true)
  section_term_set Section[] @relation("Section_term_AcademicTerm")
  courseoffering_term_set CourseOffering[] @relation("CourseOffering_term_AcademicTerm")
  exam_term_set Exam[] @relation("Exam_term_AcademicTerm")
  studenttermresult_term_set StudentTermResult[] @relation("StudentTermResult_term_AcademicTerm")
  feestructure_term_set FeeStructure[] @relation("FeeStructure_term_AcademicTerm")
  feeinvoice_term_set FeeInvoice[] @relation("FeeInvoice_term_AcademicTerm")
  student_current_term_set Student[] @relation("Student_current_term_AcademicTerm")
  @@map("academic_academicterm")
}

model AcademicYear {
  id BigInt @id @default(autoincrement())
  name String @unique
  start_date DateTime
  end_date DateTime
  is_current Boolean @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  is_active Boolean @default(true)
  academicterm_academic_year_set AcademicTerm[] @relation("AcademicTerm_academic_year_AcademicYear")
  hostelapplication_academic_year_set HostelApplication[] @relation("HostelApplication_academic_year_AcademicYear")
  holidaylist_academic_year_set HolidayList[] @relation("HolidayList_academic_year_AcademicYear")
  placementdrive_academic_year_set PlacementDrive[] @relation("PlacementDrive_academic_year_AcademicYear")
  @@map("academic_academicyear")
}

model Batch {
  id BigInt @id @default(autoincrement())
  program_id BigInt
  program Program @relation("Batch_program_Program", fields: [program_id], references: [id])
  name String
  start_year Int
  end_year Int
  max_strength Int?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  is_active Boolean @default(true)
  section_batch_set Section[] @relation("Section_batch_Batch")
  alumni_batch_set Alumni[] @relation("Alumni_batch_Batch")
  announcement_batch_set Announcement[] @relation("Announcement_batch_Batch")
  feestructure_batch_set FeeStructure[] @relation("FeeStructure_batch_Batch")
  student_batch_set Student[] @relation("Student_batch_Batch")
  @@map("academic_batch")
}

model Program {
  id BigInt @id @default(autoincrement())
  department_id BigInt
  department Department @relation("Program_department_Department", fields: [department_id], references: [id])
  name String
  code String
  level String
  duration_years Decimal
  total_terms Int
  total_credits Int?
  grading_scheme_id BigInt?
