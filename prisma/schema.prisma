  description String @default("")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  is_active Boolean @default(true)
  batch_program_set Batch[] @relation("Batch_program_Program")
  alumni_program_set Alumni[] @relation("Alumni_program_Program")
  announcement_program_set Announcement[] @relation("Announcement_program_Program")
  programcourse_program_set ProgramCourse[] @relation("ProgramCourse_program_Program")
  feestructure_program_set FeeStructure[] @relation("FeeStructure_program_Program")
  jobposting_eligible_programs_set JobPosting[] @relation("JobPosting_eligible_programs_Program")
  application_program_set Application[] @relation("Application_program_Program")
  student_program_set Student[] @relation("Student_program_Program")
